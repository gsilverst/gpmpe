{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run GPMPE Backend",
			"type": "shell",
			"command": "cd backend && ../.venv/bin/python -m uvicorn app.main:app --host 127.0.0.1 --port 8000",
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "Run GPMPE Frontend",
			"type": "shell",
			"command": "cd frontend && npm run dev -- --hostname 127.0.0.1",
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "Test GPMPE Backend",
			"type": "shell",
			"command": "cd backend && ../.venv/bin/python -m pytest -q",
			"group": "test",
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			}
		},
		{
			"label": "Test GPMPE Frontend",
			"type": "shell",
			"command": "cd frontend && npm test",
			"group": "test",
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			}
		}
	]
}